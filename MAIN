   Name = "Chaktomuk II",
   Icon = 0, -- Icon in Topbar. Can use Lucide Icons (string) or Roblox Image (number). 0 to use no icon (default).
   LoadingTitle = "lol",
   LoadingSubtitle = "by Heng",
   ShowText = "Wellcom", -- for mobile users to unhide Rayfield, change if you'd like
   Theme = "Default", -- Check https://docs.sirius.menu/rayfield/configuration/themes

   ToggleUIKeybind = "K", -- The keybind to toggle the UI visibility (string like "K" or Enum.KeyCode)

   DisableRayfieldPrompts = false,
   DisableBuildWarnings = false, -- Prevents Rayfield from emitting warnings when the script has a version mismatch with the interface.

   -- ScriptID = "sid_xxxxxxxxxxxx", -- Your Script ID from developer.sirius.menu — enables analytics, managed keys, and script hosting

   ConfigurationSaving = {
      Enabled = true,
      FolderName = nil, -- Create a custom folder for your hub/game
      FileName = "Big Hub"
   },

   Discord = {
      Enabled = false, -- Prompt the user to join your Discord server if their executor supports it
      Invite = "", -- The Discord invite code, do not include Discord.gg/. E.g. Discord.gg/ABCD would be ABCD
      RememberJoins = true -- Set this to false to make them join the Discord every time they load it up
   },

   KeySystem = false, -- Set this to true to use our key system
   KeySettings = {
      Title = "Untitled",
      Subtitle = "Key System",
      Note = "No method of obtaining the key is provided", -- Use this to tell the user how to get a key
      FileName = "Key", -- It is recommended to use something unique, as other scripts using Rayfield may overwrite your key file
      SaveKey = true, -- The user's key will be saved, but if you change the key, they will be unable to use your script
      GrabKeyFromSite = false, -- If this is true, set Key below to the RAW site you would like Rayfield to get the key from
      Key = {"Hello"} -- List of keys that the system will accept, can be RAW file links (pastebin, github, etc.) or simple strings ("hello", "key22")
   }
})
local Tab = Window:CreateTab("Farm") -- Title, Image

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local VirtualInputManager = game:GetService("VirtualInputManager")

local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem", 7)
if not FishingSystem then return warn("[Error] មិនរកឃើញប្រព័ន្ធស្ទូចត្រីទេ!") end

local FishingModules = FishingSystem:WaitForChild("FishingModules", 5)
local ShakeSystem = FishingModules and require(FishingModules:WaitForChild("ShakeSystem"))
local MinigameSystem = FishingModules and require(FishingModules:WaitForChild("MinigameSystem"))
local PowerBarSystem = FishingModules and FishingModules:FindFirstChild("PowerBarSystem") and require(FishingModules.PowerBarSystem)

-- Configuration Flag
_G.AutoFishingPerfectV16 = false

-- កំណត់ត្រាចំនួនត្រីដែលស្ទូចបាន ដើម្បីធ្វើការសម្រាកស្វ័យប្រវត្តិ (Anti-Pattern Break)
local fishCaughtSession = 0
local nextBreakLimit = math.random(5, 12) -- សម្រាកម្តងរាល់ពេលស្ទូចបានចន្លោះពី ៥ ទៅ ១២ ក្បាល

-- ជំនួយការបង្កើតល្បឿនចៃដន្យបែបធម្មជាតិ (Human Focus Simulator ជំនាន់ទី២ កាន់តែចៃដន្យ)
local function getHumanizedDelay(baseMin, baseMax)
    local t = tick()
    local wave = math.sin(t / (math.random(3, 7))) * 0.08 -- បន្ថែមភាពរលកមិនទៀងទាត់
    local randomOffset = math.random(-35, 35) / 1000
    return math.clamp(math.random(baseMin * 100, baseMax * 100) / 100 + wave + randomOffset, baseMin * 0.4, baseMax * 1.8)
end

local function getRodAndRemotes()
    local character = LocalPlayer.Character
    if not character then return nil, nil end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if not tool then
        for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
            if item:IsA("Tool") and (string.find(string.lower(item.Name), "rod") or item.Name == "Umbrella") then
                item.Parent = character
                task.wait(getHumanizedDelay(0.6, 1.2)) -- ពន្យារពេលបំពាក់ដងសន្ទូច
                tool = item
                break
            end
        end
    end
    
    if tool then
        local tapRemote = FishingSystem:FindFirstChild("Tap") or FishingSystem:FindFirstChild("Click") or FishingSystem:FindFirstChild("Reel")
        return tool, tapRemote
    end
    return nil, nil
end

-- ========================================================
-- [ប្រព័ន្ធ Shake ការពារការចាប់បាន (No-Pattern Shake)]
-- ========================================================
local function forceClickShake(shakeButton)
    if not shakeButton or not shakeButton.Visible then return end
    
    while shakeButton.Visible and _G.AutoFishingPerfectV16 do
        local connections = getconnections or get_signal_cons
        
        -- ក្លែងធ្វើការចុចលើទីតាំងចៃដន្យនៅលើអេក្រង់ (មិនមែនកូអរដោនេ 0, 0 ថេរទេ)
        local screenWidth = workspace.CurrentCamera.ViewportSize.X
        local screenHeight = workspace.CurrentCamera.ViewportSize.Y
        local randomX = math.random(screenWidth * 0.4, screenWidth * 0.6)
        local randomY = math.random(screenHeight * 0.4, screenHeight * 0.6)
        
        if connections then
            for _, clickedConnection in ipairs(connections(shakeButton.MouseButton1Click)) do 
                clickedConnection:Fire() 
            end
            pcall(function()
                for _, clickedConnection in ipairs(connections(shakeButton.Activated)) do 
                    clickedConnection:Fire() 
                end
            end)
        end
        
        if ShakeSystem and ShakeSystem.isActive then
            pcall(function()
                -- បន្ថែមល្បឿនចុចខុសៗគ្នា (ពេលខ្លះចុចលឿន ពេលខ្លះចុចយឺត)
                if math.random(1, 10) > 3 then
                    ShakeSystem:HandleClick(nil)
                end
            end)
        end
        task.wait(getHumanizedDelay(0.12, 0.25)) -- កើនឡើងការយឺតយ៉ាវបន្តិចដើម្បីឱ្យដូចមនុស្សចុចពិតៗ
    end
end

-- ប្រព័ន្ធតាមដានប៊ូតុង Shake
task.spawn(function()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local fishingGui = playerGui:WaitForChild("FishingGui", 5)
    if fishingGui then
        local shakeButton = fishingGui:WaitForChild("ShakeButton", 5)
        if shakeButton then
            shakeButton:GetPropertyChangedSignal("Visible"):Connect(function()
                if shakeButton.Visible and _G.AutoFishingPerfectV16 then 
                    task.wait(getHumanizedDelay(0.35, 0.70)) -- រង់ចាំបន្តិចមុនពេលចាប់ផ្តើម Shake (កុំឱ្យលឿនពេក)
                    forceClickShake(shakeButton) 
                end
            end)
        end
    end
end)

-- ========================================================
-- [ប្រព័ន្ធទាញត្រីបែបមនុស្ស (Organic / Semi-Auto Hooking)]
-- ========================================================
task.spawn(function()
    while true do
        task.wait(0.1)
        if _G.AutoFishingPerfectV16 and MinigameSystem and MinigameSystem:IsActive() then
            
            pcall(function()
                local debug_getupvalues = debug.getupvalues or getupvalues
                local debug_setupvalue = debug.setupvalue or setupvalue
                
                if debug_getupvalues and debug_setupvalue then
                    for _, upvalue in ipairs(debug_getupvalues(MinigameSystem.Start)) do
                        if type(upvalue) == "table" and upvalue.active ~= nil then
                            
                            task.spawn(function()
                                while MinigameSystem:IsActive() and _G.AutoFishingPerfectV16 do
                                    -- បង្កើនភាគរយលេងលក្ខណៈធម្មជាតិ (២៥% ធ្វើជាលែងខុស ឬលែងដៃតិចៗ)
                                    if math.random(1, 100) <= 25 then
                                        upvalue.isAutoMode = false
                                        task.wait(getHumanizedDelay(0.15, 0.45))
                                    else
                                        upvalue.isAutoMode = true
                                    end
                                    task.wait(getHumanizedDelay(0.18, 0.35))
                                end
                            end)
                            
                            break
                        end
                    end
                end
            end)

            while MinigameSystem:IsActive() do
                task.wait(0.1)
            end
            
            -- កត់ត្រាចំនួនត្រីដែលស្ទូចបាន និងរៀបចំប្រព័ន្ធសម្រាក
            fishCaughtSession = fishCaughtSession + 1
            task.wait(getHumanizedDelay(1.5, 3.5))
        end
    end
end)

-- ========================================================
-- [ប្រព័ន្ធបង់សន្ទូចស្វ័យប្រវត្តិ - កែសម្រួលថ្មីបំផុត និង Safe បំផុត]
-- ========================================================
task.spawn(function()
    while true do
        task.wait(0.5)
        
        if _G.AutoFishingPerfectV16 then
            -- ប្រព័ន្ធសម្រាកស្វ័យប្រវត្ត (Auto Break System) ដើម្បីជៀសវាងការស្ទូចជាប់គ្នាមិនឈប់
            if fishCaughtSession >= nextBreakLimit then
                local breakTime = math.random(5, 15) -- សម្រាកពី ៥ ទៅ ១៥ វិនាទី
                warn("[Anti-Cheat Safety] ស្គ្រីបកំពុងធ្វើការសម្រាករយៈពេល " .. tostring(breakTime) .. " វិនាទី ដើម្បីការពារគណនីរបស់អ្នក...")
                task.wait(breakTime)
                fishCaughtSession = 0
                nextBreakLimit = math.random(6, 14) -- កំណត់ចំនួនគោលដៅបន្ទាប់ជាលក្ខណៈចៃដន្យ
            end

            local currentRod, _ = getRodAndRemotes()
            
            if currentRod then
                local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
                local fishingGui = playerGui and playerGui:FindFirstChild("FishingGui")
                local shakeButton = fishingGui and fishingGui:FindFirstChild("ShakeButton")
                local fishingFrame = fishingGui and fishingGui:FindFirstChild("Fishing")
                
                -- ពិនិត្យស្ថានភាពជាប់រវល់
                local isBusy = false
                if (shakeButton and shakeButton.Visible) or (fishingFrame and fishingFrame.Visible) then isBusy = true end
                if (ShakeSystem and ShakeSystem.isActive) or (MinigameSystem and MinigameSystem:IsActive()) then isBusy = true end
                if PowerBarSystem and PowerBarSystem:IsCharging() then isBusy = true end
                
                -- បើទំនេរ ទើបចាប់ផ្តើមបោះសន្ទូច
                if not isBusy then
                    pcall(function()
                        task.wait(getHumanizedDelay(0.6, 1.4))
                        
                        -- ក្លែងធ្វើការចុចសាកកម្លាំងនៅលើកូអរដោនេចៃដន្យ (Random Screen Click Position)
                        local screenWidth = workspace.CurrentCamera.ViewportSize.X
                        local screenHeight = workspace.CurrentCamera.ViewportSize.Y
                        local randomX = math.random(screenWidth * 0.3, screenWidth * 0.7)
                        local randomY = math.random(screenHeight * 0.3, screenHeight * 0.7)
                        
                        VirtualInputManager:SendMouseButtonEvent(randomX, randomY, 0, true, game, 1)
                        
                        -- រង់ចាំឱ្យរបារកម្លាំងរត់ឡើងដល់ចំណុចល្អបំផុត
                        local chargeTime = 0
                        local maxChargeLimit = math.random(65, 88) / 100 -- សាកកម្លាំងចន្លោះ 65% ទៅ 88% ដើម្បីកុំឱ្យ Perfect រាល់ដងពេក
                        
                        while chargeTime < maxChargeLimit and _G.AutoFishingPerfectV16 do
                            task.wait(0.05)
                            chargeTime = chargeTime + 0.05
                            
                            if PowerBarSystem and PowerBarSystem:GetCurrentPower() >= math.random(80, 96) then
                                break
                            end
                        end
                        
                        -- លែងដៃដើម្បីបោះសន្ទូច (Simulate Release)
                        VirtualInputManager:SendMouseButtonEvent(randomX, randomY, 0, false, game, 1)
                        
                        -- បន្ថែម Micro-Rotation (បង្វិលខ្លួនតួអង្គបន្តិចៗរាល់ពេលបោះ ដើម្បីកុំឱ្យឈរធ្មឹងដដែលៗ)
                        local rootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if rootPart then
                            pcall(function()
                                local currentCFrame = rootPart.CFrame
                                local randomAngle = math.rad(math.random(-5, 5)) -- បង្វិលឆ្វេងស្តាំប្រមាណ -៥ ទៅ ៥ អង្សារ
                                rootPart.CFrame = currentCFrame * CFrame.Angles(0, randomAngle, 0)
                            end)
                        end
                    end)
                    
                    -- ទុកពេលឱ្យកូនដុំសន្ទូចធ្លាក់ចូលទឹក និងការពារការចុចជាន់គ្នា
                    task.wait(getHumanizedDelay(3.0, 5.0))
                end
            end
        end
    end
end)


-- Essential Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- Configuration Setup
local spots = {
    "DeliverySpot", "DeliverySpot1", "DeliverySpot2", "DeliverySpot3", 
    "DeliverySpot4", "DeliverySpot5", "DeliverySpot6", "DeliverySpot7", 
    "DeliverySpot8", "DeliverySpot9"
}
local FOOD_ITEM_NAME = "Food" 
local isScriptRunning = false -- Track toggle state

-- Helper Functions
local function humanWait(min, max)
    local randomTime = math.random(min * 100, max * 100) / 100
    task.wait(randomTime)
end

local function hasFood()
    local character = player.Character
    if character and character:FindFirstChild(FOOD_ITEM_NAME) then return true end
    if player.Backpack:FindFirstChild(FOOD_ITEM_NAME) then return true end
    
    if character then
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Tool") and string.find(string.lower(child.Name), "food") then return true end
        end
    end
    for _, child in ipairs(player.Backpack:GetChildren()) do
        if child:IsA("Tool") and string.find(string.lower(child.Name), "food") then return true end
    end
    return false
end

local function findActiveDeliverySpot(deliveryLocation)
    if not deliveryLocation then return nil end
    for _, spotName in ipairs(spots) do
        local spotPart = deliveryLocation:FindFirstChild(spotName)
        if spotPart and spotPart:IsA("BasePart") then
            if math.abs(spotPart.Transparency - 0.4) < 0.05 then
                return spotPart
            end
        end
    end
    return nil
end

-- Anti-Ban Teleport Engine
local function antiBanTeleport(targetPart)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart or not targetPart then return end
    
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    
    local noclip = RunService.Stepped:Connect(function()
        if character then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
    
    local offsetX = (math.random(-10, 10) / 10)
    local offsetZ = (math.random(-10, 10) / 10)
    local targetPos = targetPart.Position + Vector3.new(offsetX, 2.0, offsetZ)
    
    rootPart.CFrame = CFrame.new(targetPos)
    
    rootPart.Anchored = true
    task.wait(0.05)
    rootPart.Anchored = false
    
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    
    noclip:Disconnect()
    humanWait(0.08, 0.18)
end

-- Core Delivery Engine Run Routine
local function runDeliveryRoutine()
    while isScriptRunning do
        local character = player.Character or player.CharacterAdded:Wait()
        local rootPart = character:WaitForChild("HumanoidRootPart")
        
        local targetPart = workspace.Building["Prop Building"].FoodPickup
        local deliveryLocation = workspace:FindFirstChild("DeliveryLocation")
        
        print("--- Start New Anti-Ban Sequence ---")

        -- Step 1: Collect Food
        if targetPart and rootPart and not hasFood() then
            local attempt = 0
            while not hasFood() and attempt < 5 and isScriptRunning do
                attempt = attempt + 1
                print("Teleporting to FoodPickup... Attempt: " .. attempt)
                
                antiBanTeleport(targetPart)
                
                local prompt = targetPart:FindFirstChildOfClass("ProximityPrompt")
                if not prompt then
                    prompt = workspace.Building["Prop Building"].FoodPickup:FindFirstChildOfClass("ProximityPrompt")
                end
                
                if prompt then
                    prompt.RequiresLineOfSight = false
                    prompt.HoldDuration = 0 
                    task.wait(0.02)
                    prompt:InputHoldBegin()
                    prompt:InputHoldEnd()
                else
                    print("[Warning] ProximityPrompt not found!")
                end
                task.wait(0.5) 
            end
        end

        if not isScriptRunning then break end
        humanWait(0.2, 0.5)

        -- Step 2: Deliver Food
        if deliveryLocation and rootPart and hasFood() then
            local activeSpot = nil
            local scanAttempt = 0
            
            while not activeSpot and scanAttempt < 10 and isScriptRunning do
                scanAttempt = scanAttempt + 1
                activeSpot = findActiveDeliverySpot(deliveryLocation)
                if not activeSpot then task.wait(0.1) end
            end
            
            if activeSpot and isScriptRunning then
                print("🎯 Found Spot: " .. activeSpot.Name .. " | Teleporting...")
                antiBanTeleport(activeSpot)
                
                local deliveryPrompt = activeSpot:FindFirstChildOfClass("ProximityPrompt")
                if deliveryPrompt then
                    deliveryPrompt.RequiresLineOfSight = false
                    deliveryPrompt.HoldDuration = 0
                    task.wait(0.02)
                    deliveryPrompt:InputHoldBegin()
                    deliveryPrompt:InputHoldEnd()
                end
                
                humanWait(1.5, 2.5)
                print("✅ Successfully Delivered!")
            else
                print("[Warning] No active delivery zone found!")
            end
        end

        if not isScriptRunning then break end

        -- Safe Cooldown Cycle
        local cooldown = math.random(61, 71)
        print("--- Cycle Finished. Anticheat Spoof Cooldown: " .. cooldown .. "s ---")
        
        -- Safe chunked wait loop to keep UI highly responsive to toggle turns
        for i = 1, cooldown do
            if not isScriptRunning then break end
            task.wait(1)
        end
    end
end

-- Rayfield UI Toggle Linkage
local Toggle = Tab:CreateToggle({
   Name = "Auto Deliver Food",
   CurrentValue = false,
   Flag = "AutoDeliverFlag", 
   Callback = function(Value)
       isScriptRunning = Value
       
       if Value then
           -- Spawns the automation sequence loop asynchronously
           task.spawn(runDeliveryRoutine)
       else
           print("🛑 Auto Deliver System Stopped.")
       end
   end,
})

-- Rayfield Toggle UI Component
local Toggle = Tab:CreateToggle({
   Name = "Auto Fishing",
   CurrentValue = false,
   Flag = "AutoFishing16Flag", 
   Callback = function(Value)
       _G.AutoFishingPerfectV16 = Value
       if not Value then
           fishCaughtSession = 0
       end
   end,
})
