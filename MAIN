local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
   Name = "Chaktomuk II",
   Icon = 0, -- Icon in Topbar. Can use Lucide Icons (string) or Roblox Image (number). 0 to use no icon (default).
   LoadingTitle = "lodsl",
   LoadingSubtitle = "by Heng",
   ShowText = "Wellcom", -- for mobile users to unhide Rayfield, change if you'd like
   Theme = "Default", -- Check https://docs.sirius.menu/rayfield/configuration/themes

   ToggleUIKeybind = "K", -- The keybind to toggle the UI visibility (string like "K" or Enum.KeyCode)

   DisableRayfieldPrompts = false,
   DisableBuildWarnings = false, -- Prevents Rayfield from emitting warnings when the script has a version mismatch with the interface.

   -- ScriptID = "sid_xxxxxxxxxxxx", -- Your Script ID from developer.sirius.menu вҖ” enables analytics, managed keys, and script hosting

   ConfigurationSaving = {
      Enabled = true,
      FolderName = nil, -- Create a custom folder for your hub/game
      FileName = "Big Hub"
   },

   Discord = {
      Enabled = false, -- Prompt the user to join your Discord server if their executor supports it
      Invite = "", -- The Discord invite code, do not include Discord.gg/. E.g. Discord.gg/ABCD would be ABCD
      RememberJoins = true -- Set this to false to make them join the Discord every time they load it up
   },

   KeySystem = false, -- Set this to true to use our key system
   KeySettings = {
      Title = "Untitled",
      Subtitle = "Key System",
      Note = "No method of obtaining the key is provided", -- Use this to tell the user how to get a key
      FileName = "Key", -- It is recommended to use something unique, as other scripts using Rayfield may overwrite your key file
      SaveKey = true, -- The user's key will be saved, but if you change the key, they will be unable to use your script
      GrabKeyFromSite = false, -- If this is true, set Key below to the RAW site you would like Rayfield to get the key from
      Key = {"Hello"} -- List of keys that the system will accept, can be RAW file links (pastebin, github, etc.) or simple strings ("hello", "key22")
   }
})

local Tab = Window:CreateTab("Farm") -- Title, Image

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")

local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem", 7)
if not FishingSystem then return warn("[Error] бһҳбһ·бһ“бһҡбһҖбһғбһҫбһүбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҹбҹ’бһ‘бһјбһ…бһҸбҹ’бһҡбһёбһ‘бҹҒ!") end

local FishingModules = FishingSystem:WaitForChild("FishingModules", 5)
local ShakeSystem = FishingModules and require(FishingModules:WaitForChild("ShakeSystem"))
local MinigameSystem = FishingModules and require(FishingModules:WaitForChild("MinigameSystem"))
local PowerBarSystem = FishingModules and FishingModules:FindFirstChild("PowerBarSystem") and require(FishingModules.PowerBarSystem)

-- бһ—бҹ’бһҮбһ¶бһ”бҹӢбһ‘бҹ…бһҖбһ¶бһ“бҹӢбһ”бҹҠбһјбһҸбһ»бһ„ TapMobile (бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҸбҹӮ Mobile бһ‘бҹҒ)
local playerGui = LocalPlayer:WaitForChild("PlayerGui")
local fishingGui = playerGui:WaitForChild("FishingGui", 7)
local tapMobileParent = fishingGui and fishingGui:WaitForChild("TapMobile", 5)
local tapMobileButton = tapMobileParent and tapMobileParent:WaitForChild("TapMobile", 5)

-- Configuration Flag
_G.AutoFishingPerfectV16 = false

-- бһҖбҹҶбһҺбһҸбҹӢбһҸбҹ’бһҡбһ¶бһ…бҹҶбһ“бһҪбһ“бһҸбҹ’бһҡбһёбһҠбҹӮбһӣбһҹбҹ’бһ‘бһјбһ…бһ”бһ¶бһ“ бһҠбһҫбһҳбҹ’бһ”бһёбһ’бҹ’бһңбһҫбһҖбһ¶бһҡбһҹбһҳбҹ’бһҡбһ¶бһҖбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ· (Anti-Pattern Break)
local fishCaughtSession = 0
local nextBreakLimit = math.random(5, 12) -- бһҹбһҳбҹ’бһҡбһ¶бһҖбһҳбҹ’бһҸбһ„бһҡбһ¶бһӣбҹӢбһ–бҹҒбһӣбһҹбҹ’бһ‘бһјбһ…бһ”бһ¶бһ“бһ…бһ“бҹ’бһӣбҹ„бҹҮбһ–бһё бҹҘ бһ‘бҹ… бҹЎбҹў бһҖбҹ’бһ”бһ¶бһӣ

-- бһҮбҹҶбһ“бһҪбһҷбһҖбһ¶бһҡбһ”бһ„бҹ’бһҖбһҫбһҸбһӣбҹ’бһ”бһҝбһ“бһ…бҹғбһҠбһ“бҹ’бһҷбһ”бҹӮбһ”бһ’бһҳбҹ’бһҳбһҮбһ¶бһҸбһ· (Human Focus Simulator бһҮбҹҶбһ“бһ¶бһ“бҹӢбһ‘бһёбҹў бһҖбһ¶бһ“бҹӢбһҸбҹӮбһ…бҹғбһҠбһ“бҹ’бһҷ)
local function getHumanizedDelay(baseMin, baseMax)
    local t = tick()
    local wave = math.sin(t / (math.random(3, 7))) * 0.08 -- бһ”бһ“бҹ’бһҗбҹӮбһҳбһ—бһ¶бһ–бһҡбһӣбһҖбһҳбһ·бһ“бһ‘бҹҖбһ„бһ‘бһ¶бһҸбҹӢ
    local randomOffset = math.random(-35, 35) / 1000
    return math.clamp(math.random(baseMin * 100, baseMax * 100) / 100 + wave + randomOffset, baseMin * 0.4, baseMax * 1.8)
end

local function getRodAndRemotes()
    local character = LocalPlayer.Character
    if not character then return nil, nil end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if not tool then
        for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
            if item:IsA("Tool") and (string.find(string.lower(item.Name), "rod") or item.Name == "Umbrella") then
                item.Parent = character
                task.wait(getHumanizedDelay(0.6, 1.2)) -- бһ–бһ“бҹ’бһҷбһ¶бһҡбһ–бҹҒбһӣбһ”бҹҶбһ–бһ¶бһҖбҹӢбһҠбһ„бһҹбһ“бҹ’бһ‘бһјбһ…
                tool = item
                break
            end
        end
    end
    
    if tool then
        local tapRemote = FishingSystem:FindFirstChild("Tap") or FishingSystem:FindFirstChild("Click") or FishingSystem:FindFirstChild("Reel")
        return tool, tapRemote
    end
    return nil, nil
end

-- ========================================================
-- [бһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’ Shake бһҖбһ¶бһҡбһ–бһ¶бһҡбһҖбһ¶бһҡбһ…бһ¶бһ”бҹӢбһ”бһ¶бһ“ (No-Pattern Shake)]
-- ========================================================
local function forceClickShake(shakeButton)
    if not shakeButton or not shakeButton.Visible then return end
    
    while shakeButton.Visible and _G.AutoFishingPerfectV16 do
        local connections = getconnections or get_signal_cons
        
        -- бһҖбҹ’бһӣбҹӮбһ„бһ’бҹ’бһңбһҫбһҖбһ¶бһҡбһ…бһ»бһ…бһӣбһҫбһ‘бһёбһҸбһ¶бҹҶбһ„бһ…бҹғбһҠбһ“бҹ’бһҷбһ“бҹ…бһӣбһҫбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢ (бһҳбһ·бһ“бһҳбҹӮбһ“бһҖбһјбһўбһҡбһҠбҹ„бһ“бҹҒ 0, 0 бһҗбҹҒбһҡбһ‘бҹҒ)
        local screenWidth = workspace.CurrentCamera.ViewportSize.X
        local screenHeight = workspace.CurrentCamera.ViewportSize.Y
        local randomX = math.random(screenWidth * 0.4, screenWidth * 0.6)
        local randomY = math.random(screenHeight * 0.4, screenHeight * 0.6)
        
        if connections then
            for _, clickedConnection in ipairs(connections(shakeButton.MouseButton1Click)) do 
                clickedConnection:Fire() 
            end
            pcall(function()
                for _, clickedConnection in ipairs(connections(shakeButton.Activated)) do 
                    clickedConnection:Fire() 
                end
            end)
        end
        
        if ShakeSystem and ShakeSystem.isActive then
            pcall(function()
                -- бһ”бһ“бҹ’бһҗбҹӮбһҳбһӣбҹ’бһ”бһҝбһ“бһ…бһ»бһ…бһҒбһ»бһҹбҹ—бһӮбҹ’бһ“бһ¶ (бһ–бҹҒбһӣбһҒбҹ’бһӣбҹҮбһ…бһ»бһ…бһӣбһҝбһ“ бһ–бҹҒбһӣбһҒбҹ’бһӣбҹҮбһ…бһ»бһ…бһҷбһәбһҸ)
                if math.random(1, 10) > 3 then
                    ShakeSystem:HandleClick(nil)
                end
            end)
        end
        task.wait(getHumanizedDelay(0.12, 0.25)) -- бһҖбһҫбһ“бһЎбһҫбһ„бһҖбһ¶бһҡбһҷбһәбһҸбһҷбҹүбһ¶бһңбһ”бһ“бҹ’бһҸбһ·бһ…бһҠбһҫбһҳбҹ’бһ”бһёбһұбҹ’бһҷбһҠбһјбһ…бһҳбһ“бһ»бһҹбҹ’бһҹбһ…бһ»бһ…бһ–бһ·бһҸбҹ—
    end
end

-- бһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҸбһ¶бһҳбһҠбһ¶бһ“бһ”бҹҠбһјбһҸбһ»бһ„ Shake
task.spawn(function()
    if fishingGui then
        local shakeButton = fishingGui:WaitForChild("ShakeButton", 5)
        if shakeButton then
            shakeButton:GetPropertyChangedSignal("Visible"):Connect(function()
                if shakeButton.Visible and _G.AutoFishingPerfectV16 then 
                    task.wait(getHumanizedDelay(0.35, 0.70)) -- бһҡбһ„бҹӢбһ…бһ¶бҹҶбһ”бһ“бҹ’бһҸбһ·бһ…бһҳбһ»бһ“бһ–бҹҒбһӣбһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳ Shake (бһҖбһ»бҹҶбһұбҹ’бһҷбһӣбһҝбһ“бһ–бҹҒбһҖ)
                    forceClickShake(shakeButton) 
                end
            end)
        end
    end
end)

-- ========================================================
-- [бһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһ‘бһ¶бһүбһҸбҹ’бһҡбһёбһ”бҹӮбһ”бһҳбһ“бһ»бһҹбҹ’бһҹ (Organic / Semi-Auto Hooking)]
-- ========================================================
task.spawn(function()
    while true do
        task.wait(0.1)
        if _G.AutoFishingPerfectV16 and MinigameSystem and MinigameSystem:IsActive() then
            
            pcall(function()
                local debug_getupvalues = debug.getupvalues or getupvalues
                local debug_setupvalue = debug.setupvalue or setupvalue
                
                if debug_getupvalues and debug_setupvalue then
                    for _, upvalue in ipairs(debug_getupvalues(MinigameSystem.Start)) do
                        if type(upvalue) == "table" and upvalue.active ~= nil then
                            
                            task.spawn(function()
                                while MinigameSystem:IsActive() and _G.AutoFishingPerfectV16 do
                                    -- бһ”бһ„бҹ’бһҖбһҫбһ“бһ—бһ¶бһӮбһҡбһҷбһӣбҹҒбһ„бһӣбһҖбҹ’бһҒбһҺбҹҲбһ’бһҳбҹ’бһҳбһҮбһ¶бһҸбһ· (бҹўбҹҘ% бһ’бҹ’бһңбһҫбһҮбһ¶бһӣбҹӮбһ„бһҒбһ»бһҹ бһ¬бһӣбҹӮбһ„бһҠбҹғбһҸбһ·бһ…бҹ—)
                                    if math.random(1, 100) <= 25 then
                                        upvalue.isAutoMode = false
                                        task.wait(getHumanizedDelay(0.15, 0.45))
                                    else
                                        upvalue.isAutoMode = true
                                    end
                                    task.wait(getHumanizedDelay(0.18, 0.35))
                                end
                            end)
                            
                            break
                        end
                    end
                end
            end)

            while MinigameSystem:IsActive() do
                task.wait(0.1)
            end
            
            -- бһҖбһҸбҹӢбһҸбҹ’бһҡбһ¶бһ…бҹҶбһ“бһҪбһ“бһҸбҹ’бһҡбһёбһҠбҹӮбһӣбһҹбҹ’бһ‘бһјбһ…бһ”бһ¶бһ“ бһ“бһ·бһ„бһҡбҹҖбһ”бһ…бҹҶбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҹбһҳбҹ’бһҡбһ¶бһҖ
            fishCaughtSession = fishCaughtSession + 1
            task.wait(getHumanizedDelay(1.5, 3.5))
        end
    end
end)

-- ========================================================
-- [бһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһ”бһ„бҹӢбһҹбһ“бҹ’бһ‘бһјбһ…бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ· - бһҖбҹӮбһҹбһҳбҹ’бһҡбһҪбһӣбһҗбҹ’бһҳбһёбһ”бҹҶбһ•бһ»бһҸ бһ“бһ·бһ„ Safe бһ”бҹҶбһ•бһ»бһҸ]
-- ========================================================
task.spawn(function()
    while true do
        task.wait(0.4)
        
        if _G.AutoFishingPerfectV16 then
            -- бһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҹбһҳбҹ’бһҡбһ¶бһҖбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸ (Auto Break System) бһҠбһҫбһҳбҹ’бһ”бһёбһҮбҹҖбһҹбһңбһ¶бһ„бһҖбһ¶бһҡбһҹбҹ’бһ‘бһјбһ…бһҮбһ¶бһ”бҹӢбһӮбҹ’бһ“бһ¶бһҳбһ·бһ“бһҲбһ”бҹӢ
            if fishCaughtSession >= nextBreakLimit then
                local breakTime = math.random(5, 15) -- бһҹбһҳбҹ’бһҡбһ¶бһҖбһ–бһё бҹҘ бһ‘бҹ… бҹЎбҹҘ бһңбһ·бһ“бһ¶бһ‘бһё
                warn("[Anti-Cheat Safety] бһҹбҹ’бһӮбҹ’бһҡбһёбһ”бһҖбҹҶбһ–бһ»бһ„бһ’бҹ’бһңбһҫбһҖбһ¶бһҡбһҹбһҳбҹ’бһҡбһ¶бһҖбһҡбһҷбҹҲбһ–бҹҒбһӣ " .. tostring(breakTime) .. " бһңбһ·бһ“бһ¶бһ‘бһё бһҠбһҫбһҳбҹ’бһ”бһёбһҖбһ¶бһҡбһ–бһ¶бһҡбһӮбһҺбһ“бһёбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ...")
                task.wait(breakTime)
                fishCaughtSession = 0
                nextBreakLimit = math.random(6, 14) -- бһҖбҹҶбһҺбһҸбҹӢбһ…бҹҶбһ“бһҪбһ“бһӮбҹ„бһӣбһҠбҹ…бһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢбһҮбһ¶бһӣбһҖбҹ’бһҒбһҺбҹҲбһ…бҹғбһҠбһ“бҹ’бһҷ
            end

            local currentRod, _ = getRodAndRemotes()
            
            if currentRod then
                local fishingFrame = fishingGui and fishingGui:FindFirstChild("Fishing")
                local shakeButton = fishingGui and fishingGui:FindFirstChild("ShakeButton")
                
                -- бһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҹбҹ’бһҗбһ¶бһ“бһ—бһ¶бһ–бһҮбһ¶бһ”бҹӢбһҡбһңбһӣбҹӢ
                local isBusy = false
                if (shakeButton and shakeButton.Visible) or (fishingFrame and fishingFrame.Visible) then isBusy = true end
                if (ShakeSystem and ShakeSystem.isActive) or (MinigameSystem and MinigameSystem:IsActive()) then isBusy = true end
                if PowerBarSystem and PowerBarSystem:IsCharging() then isBusy = true end
                
                -- бһ”бһҫбһ‘бҹҶбһ“бҹҒбһҡ бһ‘бһҫбһ”бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳбһ”бҹ„бҹҮбһҹбһ“бҹ’бһ‘бһјбһ…
                if not isBusy then
                    pcall(function()
                        
                        -- бһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҳбһҫбһӣбһңбһ·бһ’бһёбһ…бһ»бһ… (PC Mode бһ¬ Mobile Mode)
                        if _G.FishingDeviceMode == "PC" then
                            -- [ бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢ PC ] ----------------------------------------------
                            local screenWidth = workspace.CurrentCamera.ViewportSize.X
                            local screenHeight = workspace.CurrentCamera.ViewportSize.Y
                            local randomX = math.random(screenWidth * 0.3, screenWidth * 0.7)
                            local randomY = math.random(screenHeight * 0.3, screenHeight * 0.7)
                            
                            task.wait(getHumanizedDelay(0.5, 1.2))
                            VirtualInputManager:SendMouseButtonEvent(randomX, randomY, 0, true, game, 1)
                            
                            local chargeTime = 0
                            local maxChargeLimit = math.random(65, 88) / 100
                            
                            while chargeTime < maxChargeLimit and _G.AutoFishingPerfectV16 do
                                task.wait(0.05)
                                chargeTime = chargeTime + 0.05
                                if PowerBarSystem and PowerBarSystem:GetCurrentPower() >= math.random(80, 96) then
                                    break
                                end
                            end
                            VirtualInputManager:SendMouseButtonEvent(randomX, randomY, 0, false, game, 1)
                            
                        elseif _G.FishingDeviceMode == "Mobile" and tapMobileButton and tapMobileButton.Visible and tapMobileButton.AbsoluteSize.X > 0 then
                            -- [ бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢ Mobile - Hold 1s & Random Wait ] ------------------------------------------
                            local position = tapMobileButton.AbsolutePosition
                            local size = tapMobileButton.AbsoluteSize
                            local x = position.X + (size.X / 2)
                            local y = position.Y + (size.Y / 2)
                            
                            local inset = GuiService:GetGuiInset()
                            x = x + inset.X
                            y = y + inset.Y
                            
                            -- бҹЎ. бһ”бҹүбҹҮбһҳбҹ’бһҡбһ¶бһҳбһҠбҹғбһ…бһ»бҹҮбһӣбһҫбһ”бҹҠбһјбһҸбһ»бһ„ (Touch Begin)
                            VirtualInputManager:SendTouchEvent("FishingTouchFinger", 0, x, y, game)
                            
                            -- бҹў. бһҡбһ„бҹӢбһ…бһ¶бҹҶ бҹЎ бһңбһ·бһ“бһ¶бһ‘бһё (бһ–бҹҒбһӣбһҖбҹҶбһ–бһ»бһ„бһ‘бһ¶бһүбһҸбҹ’бһҡбһё)
                            task.wait(1)
                            
                            -- бҹЈ. бһҠбһҖбһҳбҹ’бһҡбһ¶бһҳбһҠбҹғбһ…бҹҒбһүбһңбһ·бһү (Touch End)
                            VirtualInputManager:SendTouchEvent("FishingTouchFinger", 2, x, y, game)
                            
                            -- рҹҺҜ бһӮбһҺбһ“бһ¶бһ–бҹҒбһӣбһҡбһ„бҹӢбһ…бһ¶бҹҶ Random бһ…бһ“бҹ’бһӣбҹ„бҹҮбһ–бһё 0.7 бһ‘бҹ… 1.2 бһңбһ·бһ“бһ¶бһ‘бһё
                            local randomWait = math.random(7, 12) / 10
                            task.wait(randomWait)
                        end
                        
                        -- бһ”бһ“бҹ’бһҗбҹӮбһҳ Micro-Rotation (бһ”бһ„бҹ’бһңбһ·бһӣбһҒбҹ’бһӣбһҪбһ“бһҸбһҪбһўбһ„бҹ’бһӮбһ”бһ“бҹ’бһҸбһ·бһ…бҹ—бһҡбһ¶бһӣбҹӢбһ–бҹҒбһӣбһ”бҹ„бҹҮ бһҠбһҫбһҳбҹ’бһ”бһёбһҖбһ»бҹҶбһұбҹ’бһҷбһҲбһҡбһ’бҹ’бһҳбһ№бһ„бһҠбһҠбҹӮбһӣбҹ—)
                        local rootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if rootPart then
                            pcall(function()
                                local currentCFrame = rootPart.CFrame
                                local randomAngle = math.rad(math.random(-4, 4))
                                rootPart.CFrame = currentCFrame * CFrame.Angles(0, randomAngle, 0)
                            end)
                        end
                    end)
                    
                    -- бһ‘бһ»бһҖбһ–бҹҒбһӣбһұбҹ’бһҷбһҖбһјбһ“бһҠбһ»бҹҶбһҹбһ“бҹ’бһ‘бһјбһ…бһ’бҹ’бһӣбһ¶бһҖбҹӢбһ…бһјбһӣбһ‘бһ№бһҖ
                    task.wait(getHumanizedDelay(3.0, 4.5))
                end
            end
        end
    end
end)

-- ========================================================
-- [ бһҖбһ¶бһҡбһ”бһ„бҹ’бһҖбһҫбһҸбһ”бҹҠбһјбһҸбһ»бһ„ Toggle бһ…бҹҶбһ“бһҪбһ“ бҹў бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢ PC бһ“бһ·бһ„ Mobile ]
-- ======================================================== 
local TogglePC = Tab:CreateToggle({
   Name = '<font size="24"><b>бһҹбҹ’бһ‘бһјбһ…бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸ (PC)</b></font> Auto Fishing PC',
   CurrentValue = false,
   Flag = "AutoFishingPerfectV16PCFlag", 
   Callback = function(Value)
       _G.AutoFishingPerfectV16 = Value
       if Value then
           _G.FishingDeviceMode = "PC"
       else
           fishCaughtSession = 0
       end
   end,
})

local ToggleMobile = Tab:CreateToggle({
   Name = '<font size="24"><b>бһҹбҹ’бһ‘бһјбһ…бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸ (Mobile)</b></font> Auto Fishing Mobile',
   CurrentValue = false,
   Flag = "AutoFishingPerfectV16MobileFlag", 
   Callback = function(Value)
       _G.AutoFishingPerfectV16 = Value
       if Value then
           _G.FishingDeviceMode = "Mobile"
       else
           fishCaughtSession = 0
       end
   end,
})
